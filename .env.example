# Copiar este archivo como `.env` y completar los valores.
#
# Vite solo expone al navegador variables con prefijo VITE_.
# Tu token de Postman va en VITE_ERP_API_KEY (mismo valor que ERP_API_KEY / X-Auth-Token).

# URL base sin barra final (incluye /api/v10)
VITE_SIG_API_BASE_URL=https://secure.sig2k.com/sigmasaas/paoletti@sigma-ar/sigma/api/v10

VITE_ERP_API_KEY=

# Opcional: meta del indicador de ventas (si no se define, Ventas totales usa valores por defecto)
# VITE_SALES_GOAL=800000

# Si la API bloquea CORS desde el navegador, poné "true" y usá VITE_SIG_API_USE_PROXY más abajo.
# VITE_SIG_API_USE_PROXY=true

# Mínimo de milisegundos entre una petición a la API y la siguiente (reduce 429). Por defecto 60000 (1 min).
# VITE_SIG_API_MIN_INTERVAL_MS=60000
